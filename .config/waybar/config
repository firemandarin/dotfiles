{
  "layer": "top",
  "position": "bottom",
  "height": 32,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,
  "spacing": 6,

  "modules-left": [
    "sway/workspaces"
  ],

  "modules-center": [
    "mpris"
  ],

  "modules-right": [
    "custom/sep",
    "pulseaudio",
    "custom/sep",
    "sway/language",
    "custom/sep",
    "clock",
    "custom/sep",
    "group/tray-drawer",
    "custom/sep",
    "custom/power",
     "custom/sep"
  ],

  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": false,
    "format": "{name}",
    "enable-bar-scroll": true, 
    "reverse-scroll": false,
    "on-click": "activate"
  },
  
  "group/tray-drawer": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 200
    },
    "modules": [
      "custom/expand",
      "tray"
    ]
  },

  "custom/expand": {
    "format": "❮",
    "tooltip": false
  },
  
  "sway/window": {
    "format": {}
  },

  "mpris": {
    "format": "{artist} - {title}",
    "interval": 1
  },

  "pulseaudio": {
    "format": "vol: {volume}%",
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

  "sway/language": {
    "format": "{short}",
    "layout": "EN,HU",
    "on-click": "swaymsg input * xkb_switch_layout next"
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "none",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#b3c7cc'><b>{}</b></span>",
        "days": "<span>{}</span>",
        "today": "<span color='#b3c7cc'><b><u>{}</u></b></span>"
      }
    }
  },

  "tray": {
    "spacing": 8
  },

  "custom/sep": {
    "format": "│"
  },

  "custom/power": {
    "format": "⏻",
    "on-click": "~/.config/sway/scripts/powermenu.sh",
    "tooltip": false
  }
}
