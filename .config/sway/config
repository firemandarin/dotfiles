# =========================================================
# SWAY CONFIG (CLEAN + STABLE - DEBIAN SAFE)
# =========================================================

### VARIABLES
set $mod Mod4
set $term kitty

### INPUT / KEYBOARD
input * {
    xkb_layout us,hu
    xkb_variant ,qwerty
    xkb_options grp:alt_shift_toggle,caps:super
}

input type:pointer {
    accel_profile flat
    pointer_accel 0.0
}

focus_follows_mouse no
mouse_warping output

### APPEARANCE
gaps inner 5
smart_gaps on
font pango:Noto Sans Regular 11

default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart

seat * xcursor_theme Adwaita 24

### COLORS
client.focused          #9FA3A8 #000000 #FFFFFF #9FA3A8 #9FA3A8
client.focused_inactive #000000 #000000 #808080 #000000 #000000
client.unfocused        #000000 #000000 #808080 #000000 #000000
client.urgent           #FF5555 #FF5555 #FFFFFF #FF5555 #FF5555
client.placeholder      #000000 #000000 #FFFFFF #000000 #000000

### OUTPUT / MONITOR
#output * bg ~/Pictures/Wallpapers/daniel-leone-g30P1zcOzXo-unsplash.jpg fill
output * bg ~/Pictures/Wallpapers/wallhaven-49vrzd.jpg fill
#output "*" bg #3e646f solid_color
output DP-2 mode 2560x1440@164.958Hz adaptive_sync on

### ENVIRONMENT (FIXED FOR DEBIAN / WAYLAND)
exec_always dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

### AUTOSTART (NO DUPLICATION TRAPS)
#exec mako
#exec waybar
#exec nm-applet --indicator
#exec qbittorrent 
#exec autotiling

### AUTOSTART
### AUTOSTART
exec mako
exec_always --no-startup-id "sleep 2 && killall waybar; waybar"
exec_always --no-startup-id "sleep 2 && killall autotiling; autotiling"
exec nm-applet --indicator
exec qbittorrent
# qbittorrent removed from here if you prefer manual start

### LOCKING / IDLE (STABLE PATTERN)
exec swayidle -w \
    timeout 300 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    before-sleep '~/.config/sway/scripts/lock-macos.sh'

### IDLE RULES
# Only inhibit idle for fullscreen apps
#for_window [app_id=".*"] inhibit_idle fullscreen

### MEDIA CONTROLS
bindsym XF86AudioRaiseVolume exec pamixer -i 5
bindsym XF86AudioLowerVolume exec pamixer -d 5
bindsym XF86AudioMute exec pamixer -t
bindsym XF86AudioMicMute exec pamixer --default-source -t
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

### KEYBINDINGS (LAUNCH / APPS)
bindsym $mod+Return exec $term
bindsym $mod+space exec ~/.config/wofi/menu/menu.sh
bindsym $mod+f exec firefox
bindsym $mod+e exec thunar
bindsym $mod+g exec geany
bindsym $mod+q kill
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -B 'Yes' 'swaymsg exit'
bindsym $mod+shift+f fullscreen toggle
bindsym $mod+o exec ~/.config/sway/scripts/lock.sh
bindsym $mod+Shift+w exec swaymsg "output * dpms on"
bindsym mod1+Tab workspace next_on_output

### SCREENSHOT
bindsym $mod+Shift+s exec grim -g "$(slurp)" - | wl-copy --type image/png
bindsym $mod+Shift+p exec grim - | wl-copy --type image/png

### NAVIGATION
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

### WORKSPACES
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

### LAYOUT
bindsym $mod+h splith
bindsym $mod+v splitv
floating_modifier $mod normal
bindsym $mod+Shift+space floating toggle

mode "resize" {
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

### WINDOW RULES (CLEANED)
for_window [app_id="gsimplecal"] floating enable, move position bottom right
for_window [class="gsimplecal"] floating enable, sticky enable
for_window [class="gsimplecal"] move absolute position 1500 800
for_window [app_id="qbittorrent"] floating enable, resize set 960 540, move position center
for_window [app_id="imv"] floating enable, resize set 960 540, move position center
for_window [app_id="galculator"] floating enable, move position center
for_window [app_id="pavucontrol"] floating enable, resize set 600 400, move position center
for_window [app_id="mpv"] floating enable
for_window [app_id="io.github.celluloid_player.Celluloid"] floating enable
for_window [app_id="thunar"] floating enable, resize set 960 540, move position center
for_window [class="steam"] floating enable

### WORKSPACE ASSIGNMENTS
assign [app_id="^firefox$"] workspace number 1
assign [app_id="^spotify$"] workspace number 2
assign [app_id="^steam$"] workspace number 3
assign [app_id="^org.remmina.Remmina$"] workspace number 4

### INCLUDE EXTRA CONFIGS
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'
